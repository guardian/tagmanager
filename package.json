{
  "name": "tagmanager",
  "version": "0.0.1",
  "description": "Tool for managing Guardian tags",
  "scripts": {
    "build": "webpack --mode production --entry ./public/app.js --output-path ./public/build/ --config ./public/build_config/webpack.prod.conf.js",
    "build-dev": "webpack --output-path ./public/build/ --config ./public/build_config/webpack.dev.conf.js --watch",
    "build-icons": "svg-sprite -w 16 -h 16 -v true --view-bust false --view-prefix .i-%s --shape-id-separator '' --view-dest . --vs ./public/images/icons.svg --vscss true --view-render-scss-template ./public/images/icons/scssTemplate.scss --view-render-scss-dest ./public/style/_icons.scss  ./public/images/icons/*.svg",
    "client-dev": "node ./public/devserver.js"
  },
  "dependencies": {
    "@guardian/prosemirror-editor": "^0.2.0",
    "ajv": "^6.12.3",
    "babel-loader": "^8.2.5",
    "css-loader": "^3.6.0",
    "expose-loader": "^4.1.0",
    "lodash.debounce": "^3.1.1",
    "lodash.startcase": "^4.4.0",
    "moment": "^2.29.4",
    "panda-session": "0.1.6",
    "prop-types": "^15.8.1",
    "q": "1.4.1",
    "ramda": "^0.18.0",
    "react": "17.0.2",
    "react-dom": "17.0.2",
    "react-dropzone": "^14.0.0",
    "react-redux": "^8.0.0",
    "react-router-dom": "^6.0.0",
    "react-tooltip": "^5.0.0",
    "react-transition-group": "^4.4.5",
    "react-widgets": "^5.8.0",
    "redux": "^5.0.0",
    "redux-logger": "^3.0.6",
    "redux-thunk": "^3.1.0",
    "reqwest": "^2.0.5",
    "sass": "^1.55.0",
    "sass-loader": "^8.0.2",
    "style-loader": "^2.0.0",
    "svg-sprite": "^2.0.2",
    "webpack": "^5.84.0"
  },
  "devDependencies": {
    "@babel/core": "^7.19.3",
    "@babel/plugin-transform-object-assign": "^7.18.6",
    "@babel/preset-env": "^7.19.3",
    "@babel/preset-react": "^7.18.6",
    "@babel/preset-typescript": "^7.28.5",
    "@types/lodash.debounce": "^4.0.9",
    "@types/lodash.startcase": "^4.4.9",
    "@types/prop-types": "^15.7.15",
    "@types/q": "^1.5.8",
    "@types/ramda": "^0.31.1",
    "@types/react": "^17.0.0",
    "@types/react-dom": "^17.0.0",
    "@types/react-redux": "^7.1.34",
    "@types/redux-thunk": "^2.1.32",
    "eslint": "^4.18.2",
    "eslint-plugin-react": "^3.13.1",
    "mini-css-extract-plugin": "^1.6.2",
    "ts-morph": "^27.0.2",
    "typescript": "^6.0.2",
    "webpack-cli": "^4.10.0",
    "webpack-dev-server": "3.11.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/guardian/tagmanager"
  }
}
